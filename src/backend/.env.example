# ╔═══════════════════════════════════════════════════════════════════╗
# ║  RD-WATCH :: CONFIGURACIÓN DE ENTORNO                          ║
# ║  Copia este archivo como .env y ajusta los valores             ║
# ╚═══════════════════════════════════════════════════════════════════╝

# ──────────────────────────────────────────────────────────────────
# CONFIGURACIÓN DE BASE DE DATOS (PostgreSQL)
# ──────────────────────────────────────────────────────────────────

DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=rdwatch_db
DB_USER=postgres
DB_PASS=

# ──────────────────────────────────────────────────────────────────
# CONFIGURACIÓN DE CORREO (PHPMailer)
# ──────────────────────────────────────────────────────────────────

MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=tu-correo@gmail.com
MAIL_PASS=tu-password-de-aplicacion
MAIL_FROM=noreply@rdwatch.com
MAIL_FROM_NAME=RD-Watch

# ──────────────────────────────────────────────────────────────────
# CONFIGURACIÓN DE GOOGLE OAUTH (Opcional)
# ──────────────────────────────────────────────────────────────────

GOOGLE_CLIENT_ID=tu-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu-client-secret
GOOGLE_REDIRECT_URI=http://localhost/RD_WATCH/src/backend/api/auth_google.php

# ──────────────────────────────────────────────────────────────────
# CONFIGURACIÓN DE APLICACIÓN
# ──────────────────────────────────────────────────────────────────

APP_URL=http://localhost/RD_WATCH
APP_DEBUG=false
APP_TIMEZONE=America/Bogota

# ──────────────────────────────────────────────────────────────────
# CLAVES DE SEGURIDAD (生成 aleatorias)
# ──────────────────────────────────────────────────────────────────

SECRET_KEY=genera-una-clave-larga-y-aleatoria-aqui
JWT_SECRET=otra-clave-diferente-para-jwt
